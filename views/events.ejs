<!doctype html>
<html lang="en">
 <head><%- include('partials/head', { title: 'Events' }) %></head>
  <body>
    <%- include('partials/nav', { navLinks: [
    { href: '/bookings', label: 'Bookings' },
    { href: '/contact',  label: 'Contact' },
    { href: '/',         label: 'Login' },
    { href: '/admin/events', label: 'Admin' },
    { href: '/logout',   label: 'Sign Out', cls: 'nav-signout' }
  ]}) %>

    <div class="page-content">
      <div class="control-cont card">
        <div class="search-bar">
          <input
            class="input-std"
            type="text"
            id="events-search"
            placeholder="Search events…"
            oninput="filterEvents()"
          />
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--dark-red)"
            stroke-width="2"
            style="cursor: pointer; flex-shrink: 0"
            onclick="filterEvents()"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="M22 22l-4.35-4.35" />
          </svg>
        </div>

        <div class="filter-bar">
          <label for="filter-from">FROM:</label>
          <input
            class="input-std badge badge-red"
            style="max-width: 145px"
            type="date"
            id="filter-from"
            title="From Date"
            onchange="filterEvents()"
          />
          <label for="filter-to">TO:</label>
          <input
            class="input-std badge badge-red"
            style="max-width: 145px"
            type="date"
            id="filter-to"
            title="To Date"
            onchange="filterEvents()"
          />
          <select
            class="select-std badge badge-yellow"
            id="filter-category"
            onchange="filterEvents()"
          >
            <option value="">Select Category</option>
            <option value="Outdoors">Outdoors</option>
            <option value="Indoors">Indoors</option>
            <option value="Quiet">Quiet</option>
            <option value="Crowd">Crowd</option>
          </select>
          <select
            class="select-std badge badge-yellow"
            id="filter-seats"
            onchange="filterEvents()"
          >
            <option value="">Select Seats</option>
            <option value="any">Any Availability</option>
            <option value="10">10+ Seats</option>
            <option value="50">50+ Seats</option>
          </select>
        </div>
      </div>
      <div class="events-list" id="events-list">
        <!-- Event card — replace contents via API response -->
        <div class="event-card card" data-category="Outdoors" data-seats="89">
          <div class="event-img">
            <div class="event-img-inner">
              <img src="images/boats.jpg" alt="boats" />
            </div>
            <div class="event-footer">
              <span class="event-date"
                >11 July 2026 &nbsp;|&nbsp; 08:00 – 18:30</span
              >
            </div>
          </div>
          <div class="event-body">
            <div class="event-header">
              <span class="badge event-title">Mountain Lights</span>
              <button
                class="btn btn-yellow btn-sm underline"
                onclick="openBooking('Mountain Lights', 17.53, 1)"
              >
                Book Now!
              </button>
              <span class="badge badge-red">Outdoors</span>
              <span class="badge badge-red">89 Seats Left</span>
            </div>
            <p class="event-desc">
