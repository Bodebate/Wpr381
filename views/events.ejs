<!doctype html>
<html lang="en">
<head><%- include('partials/head', { title: 'Events' }) %></head>
<body>

  <%- include('partials/nav', { navLinks: [
    { href: '/bookings', label: 'Bookings' },
    { href: '/contact',  label: 'Contact' },
    { href: '/',         label: 'Login' },
    { href: '/admin/events', label: 'Admin' },
    { href: '/logout',   label: 'Sign Out', cls: 'nav-signout' }
  ]}) %>

  <div class="search-bar">
    <input class="input-std" type="text" id="events-search" placeholder="Search events…" oninput="filterEvents()" />
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--yellow)" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
    </svg>
  </div>

  <div class="filter-bar">
    <input class="input-std" style="max-width:145px" type="date" id="filter-from" title="From Date" onchange="filterEvents()" />
    <input class="input-std" style="max-width:145px" type="date" id="filter-to"   title="To Date"   onchange="filterEvents()" />
    <select class="select-std" id="filter-category" onchange="filterEvents()">
      <option value="">Select Category</option>
      <option>Outdoors</option><option>Indoors</option>
      <option>Quiet</option><option>Crowd</option>
    </select>
    <select class="select-std" id="filter-seats" onchange="filterEvents()">
      <option value="">Select Seats</option>
      <option value="any">Any Availability</option>
      <option value="10">10+ Seats</option>
      <option value="50">50+ Seats</option>
    </select>
  </div>

  <div class="page-content">
    <div class="events-list" id="events-list">
      <% if (events.length === 0) { %>
        <!-- Placeholder card — remove once API is wired -->
        <div class="event-card card" data-category="Outdoors" data-seats="89">
          <div class="event-img"><div class="event-img-inner"><img src="/images/boats.jpg" alt="boats" /></div></div>
          <div class="event-body">
            <div class="event-header">
              <span class="event-title">Mountain Lights</span>
              <button class="btn btn-yellow btn-sm" onclick="openBooking('Mountain Lights', 17.53, 1)">Book Now!</button>
              <span class="badge badge-yellow">Outdoors</span>
              <span class="event-seats">89 Seats Left</span>
            </div>
            <p class="event-desc">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
            <div class="event-footer"><span class="event-date">11 July 2026 &nbsp;|&nbsp; 08:00 – 18:30</span></div>
          </div>
        </div>
      <% } else { %>
        <% events.forEach(ev => { %>
          <div class="event-card card" data-category="<%= ev.category %>" data-seats="<%= ev.availableTickets %>">
            <div class="event-img"><div class="event-img-inner">
              <% if (ev.imageUrl) { %><img src="<%= ev.imageUrl %>" alt="<%= ev.title %>" /><% } %>
            </div></div>
            <div class="event-body">
              <div class="event-header">
                <span class="event-title"><%= ev.title %></span>
                <button class="btn btn-yellow btn-sm" onclick="openBooking('<%= ev.title %>', <%= ev.price %>, '<%= ev._id %>')">Book Now!</button>
                <span class="badge badge-yellow"><%= ev.category %></span>
                <span class="event-seats"><%= ev.availableTickets %> Seats Left</span>
              </div>
              <p class="event-desc"><%= ev.description %></p>
              <div class="event-footer"><span class="event-date"><%= ev.eventDate %></span></div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <script src="/basic.js"></script>
</body>
</html>
