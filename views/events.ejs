<!doctype html>
<html lang="en">
   <head><%- include('partials/head', { title: 'Events' }) %></head>
  <body>
    <%- include('partials/nav', { navLinks: [
    { href: '/contact',  label: 'Contact' },
    { href: '/admin/events', label: 'Admin' },
    { href: '/logout',   label: 'Sign Out', cls: 'nav-signout' }
  ]}) %>


    <div class="page-content">
      <div class="control-cont card">
        <div class="search-bar">
          <input
            class="input-std"
            type="text"
            id="events-search"
            placeholder="Search events…"
          />
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--dark-red)"
            stroke-width="2"
            style="cursor: pointer; flex-shrink: 0"
            onclick="filterEvents()"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="M22 22l-4.35-4.35" />
          </svg>
        </div>

        <div class="filter-bar">
          <label for="filter-from">FROM:</label>
          <input
            class="input-std badge badge-red"
            style="max-width: 145px"
            type="date"
            id="filter-from"
            title="From Date"
          />
          <label for="filter-to">TO:</label>
          <input
            class="input-std badge badge-red"
            style="max-width: 145px"
            type="date"
            id="filter-to"
            title="To Date"
          />
          <select
            class="select-std badge badge-yellow"
            id="filter-category"
          >
            <option value="">Select Category</option>
            <option value="Outdoors">Outdoors</option>
            <option value="Indoors">Indoors</option>
            <option value="Quiet">Quiet</option>
            <option value="Crowd">Crowd</option>
          </select>
          <select
            class="select-std badge badge-yellow"
            id="filter-seats"
          >
            <option value="">Select Seats</option>
            <option value="0">Any Availability</option>
            <option value="1">1+ Seats</option>
            <option value="5">5+ Seats</option>
            <option value="10">10+ Seats</option>
            <option value="50">50+ Seats</option>
            <option value="100">100+ Seats</option>
          </select>
        </div>
      </div>

      <div class="events-list" id="events-list">
        <!-- Event card — replace contents via API response -->
        <% if (events && events.length > 0) { %>
    <% events.forEach(function(event) { %>
      
      <!-- Dynamic Event Card -->
      <div class="event-card card" data-category="<%= event.category %>" data-seats="<%= event.availableTickets %>">
        <div class="event-img">
          <div class="event-img-inner">
            <!-- Dynamically loading the event image path -->
            <img src="<%= event.imageUrl || '/images/boats.jpg' %>" alt="<%= event.title %>" />
          </div>
          <div class="event-footer">
            <span class="event-date">
              <!-- Formatting the date string cleanly -->
              <%= new Date(event.eventDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %> 
              &nbsp;|&nbsp; 
              <%= event.timeRange || '08:00 – 18:30' %>
            </span>
          </div>
        </div>
        <div class="event-body">
          <div class="event-header">
            <span class="badge event-title"><%= event.title %></span>
            <button
              class="btn btn-yellow btn-sm underline"
              onclick="openBooking('<%= event.title %>', <%= event.price || 0 %>, '<%= event._id %>')"
            >
              Book Now!
            </button>
            <span class="badge badge-red"><%= event.category %></span>
            <span class="badge badge-red"><%= event.availableTickets %> Seats Left</span>
          </div>
          <p class="event-desc">
            <%= event.description %>
          </p>
        </div>
      </div>

    <% }); %>
  <% } else { %>
    <!-- Graceful state if no search matches are found -->
    <div class="no-events card">
      <p>No events match your filtering criteria.</p>
    </div>
  <% } %>
</div>
        
      </div>
    </div>

    <script src="/basic.js"></script>
  </body>
</html>
