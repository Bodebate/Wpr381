<!doctype html>
<html lang="en">
  <head><%- include('partials/head', { title: ' Enquiries' }) %></head>
  <body>
        <%- include('partials/nav', { navLinks: [
    { href: '/bookings',        label: 'Bookings' },
    { href: '/events',          label: 'Events' },
    { href: '/admin/events',    label: 'Admin' },
    { href: '/logout',          label: 'Sign Out', cls: 'nav-signout' }
  ]}) %>

    <div class="page-content">
      <!-- Search + filter bar -->
      <div class="control-cont card">
        <div class="search-bar">
          <input
            class="input-std"
            type="text"
            id="enq-search"
            placeholder="Search enquiry subjects…"
            oninput="filterEnquiries()"
          />
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--dark-red)"
            stroke-width="2"
            style="cursor: pointer; flex-shrink: 0"
            onclick="filterEnquiries()"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="M22 22l-4.35-4.35" />
          </svg>
        </div>
        <div class="filter-bar">
          <label for="enq-from">FROM:</label>
          <input
            class="input-std badge badge-red"
            style="max-width: 145px"
            type="date"
            id="enq-from"
            onchange="filterEnquiries()"
          />
          <label for="enq-to">TO:</label>
          <input
            class="input-std badge badge-red"
            style="max-width: 145px"
            type="date"
            id="enq-to"
            onchange="filterEnquiries()"
          />
          <select
            class="select-std badge badge-yellow"
            id="enq-status-filter"
            onchange="filterEnquiries()"
          >
            <option value="">Select Status</option>
            <option value="open">Open</option>
            <option value="closed">Closed</option>
            <option value="pending">Pending</option>
          </select>
        </div>
      </div>

      <!-- Expanded enquiry detail panel (hidden until Edit is clicked) -->
      <div class="enquiry-expanded card" id="enquiry-detail-panel">
        <!-- Body: message left, fields right -->
        <div class="enq-panel-body">
          <div class="enq-message-area">
            <textarea
              id="enq-d-message"
              readonly
              placeholder="Message content will appear here…"
            ></textarea>
          </div>

          <div class="enq-fields-area">
            <!-- Action header -->
            <div class="enq-panel-header">
              <label for="status-pill">Status:</label>
              <select
                class="status-pill"
                id="enq-panel-status"
                name:"status-pill"
                onchange="handleStatusChange(event, null)"
              >
                <option value="open" selected>OPEN</option>
                <option value="closed">CLOSED</option>
                <option value="pending">PENDING</option>
              </select>
              <button
                class="btn btn-danger btn-sm"
                onclick="handleDeleteEnquiry(event, null)"
              >
                Delete
              </button>
              <button
                class="btn btn-yellow btn-sm"
                onclick="handleUpdateEnquiry(event)"
              >
                Update
              </button>
              <button
                class="panel-toggle"
                id="enq-panel-toggle"
                onclick="toggleEnquiryPanel()"
                title="Collapse"
              >
                /\
              </button>
            </div>
            <div class="enq-field">
              <label>Name:</label>
              <input type="text" id="enq-d-name" readonly />
            </div>
            <div class="enq-field">
              <label>Email:</label>
              <input type="text" id="enq-d-email" readonly />
            </div>
            <div class="enq-field">
              <label>Subject:</label>
              <input type="text" id="enq-d-subject" readonly />
            </div>
            <div class="enq-field">
              <label>Create Date:</label>
              <input type="text" id="enq-d-created" readonly />
            </div>
            <div class="enq-field">
              <label>Last Update:</label>
              <input type="text" id="enq-d-updated" readonly />
            </div>
            <div class="enq-field">
              <label>Handled By:</label>
              <input
                type="text"
                id="enq-d-handler"
                placeholder="Assign handler…"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Enquiry list — replace with API response -->
      <div id="enquiry-list">
        <div class="enquiry-item card">
          <div class="enq-item-field">
            <span class="key">Subject:</span>
            <span class="val">Event cancellation query</span>
          </div>
          <div class="enq-item-field">
            <span class="key">Last Update:</span>
            <span class="val">14 Jun 2025 14:35</span>
          </div>
          <span class="badge badge-yellow">OPEN</span>
          <div class="enq-actions">
            <button
              class="btn btn-danger btn-sm"
              onclick="handleDeleteEnquiry(event, 1)"
            >
              Delete
            </button>
            <button
              class="btn btn-yellow btn-sm"
              onclick="handleEditEnquiry(event, 1)"
            >
              Edit
            </button>
          </div>
        </div>

        <div class="enquiry-item card">
          <div class="enq-item-field">
            <span class="key">Subject:</span>
            <span class="val">Refund request</span>
          </div>
          <div class="enq-item-field">
            <span class="key">Last Update:</span>
            <span class="val">12 Jun 2025 09:10</span>
          </div>
          <span class="badge badge-yellow">CLOSED</span>
          <div class="enq-actions">
            <button
              class="btn btn-danger btn-sm"
              onclick="handleDeleteEnquiry(event, 2)"
            >
              Delete
            </button>
            <button
              class="btn btn-yellow btn-sm"
              onclick="handleEditEnquiry(event, 2)"
            >
              Edit
            </button>
          </div>
        </div>

        <div class="enquiry-item card">
          <div class="enq-item-field">
            <span class="key">Subject:</span>
            <span class="val">Accessibility question</span>
          </div>
          <div class="enq-item-field">
            <span class="key">Last Update:</span>
            <span class="val">10 Jun 2025 17:22</span>
          </div>
          <span class="badge badge-yellow">PENDING</span>
          <div class="enq-actions">
            <button
              class="btn btn-danger btn-sm"
              onclick="handleDeleteEnquiry(event, 3)"
            >
              Delete
            </button>
            <button
              class="btn btn-yellow btn-sm"
              onclick="handleEditEnquiry(event, 3)"
            >
              Edit
            </button>
          </div>
        </div>
      </div>
    </div>

    <script src="basic.js"></script>
    <script>
      function toggleEnquiryPanel() {
        document
          .getElementById("enquiry-detail-panel")
          .classList.remove("open");
      }
    </script>
  </body>
</html>
