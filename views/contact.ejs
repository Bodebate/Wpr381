<!doctype html>
<html lang="en">
<head><%- include('partials/head', { title: 'Contact' }) %></head>
<body>

  <%- include('partials/nav', { navLinks: [
    { href: '/bookings', label: 'Bookings' },
    { href: '/events',   label: 'Events' },
    { href: '/logout',   label: 'Sign Out', cls: 'nav-signout' }
  ]}) %>

  <div class="page-content">
    <div class="contact-wrap card">
      <div class="contact-fields">
        <form action="/contact" method="POST">
          <div class="form-group">
            <label>Name</label>
            <input class="input-std" type="text" name="name" autocomplete="name" />
          </div>
          <div class="form-group">
            <label>Email</label>
            <input class="input-std" type="email" name="email" autocomplete="email" />
          </div>
          <div class="form-group">
            <label>Subject</label>
            <input class="input-std" type="text" name="subject" />
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea class="input-std" name="message" rows="4" style="resize:vertical"></textarea>
          </div>
          <button class="btn btn-yellow" type="submit">Send Enquiry ›</button>
        </form>
      </div>
      <div class="contact-info">
        <p>Please remember to be as detailed as possible to give us the best chance of being able to assist you.</p>
      </div>
    </div>
  </div>

</body>
</html>
