<!doctype html>
<html lang="en">
<head><%- include('partials/head', { title: 'Register / Log In' }) %></head>
<body class="auth-page">

  <%- include('partials/nav', { navClass: 'nav-center' }) %>

  <form class="auth-card card" action="/register" method="POST" id="auth-form">
    <div class="form-group">
      <label>First Name:</label>
      <input class="input-std" type="text" name="firstName" autocomplete="given-name" />
    </div>
    <div class="form-group">
      <label>Surname:</label>
      <input class="input-std" type="text" name="lastName" autocomplete="family-name" />
    </div>
    <div class="form-group">
      <label>Phone No.:</label>
      <input class="input-std" type="tel" name="phoneNumber" autocomplete="tel" />
    </div>
    <div class="form-group">
      <label>Email:</label>
      <input class="input-std" type="email" name="email" autocomplete="email" />
    </div>
    <div class="form-group">
      <label>Password:</label>
      <input class="input-std" type="password" name="password" autocomplete="current-password" />
    </div>
    <div class="auth-actions">
      <button class="btn btn-red"    type="submit" formaction="/register">Register</button>
      <button class="btn btn-yellow" type="submit" formaction="/login">Log In</button>
    </div>
  </form>

</body>
</html>
