<!doctype html>
<html lang="en">
  <head><%- include('partials/head', { title: 'Home' }) %></head>

  <body class="auth-page">
     <%- include('partials/nav', { navClass: 'nav-center' }) %>


    <div class="auth-card card">
      <form id="auth-form" action="/register" method="POST">
      <% if (error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>
      <div class="form-group">
        <label>First Name:</label>
        <input class="input-std" type="text" name="firstName" id="reg-name" autocomplete="given-name" required />
      </div>
      <div class="form-group">
        <label>Surname:</label>
        <input class="input-std" type="text" name="surname" id="reg-surname" autocomplete="family-name" required />
      </div>
      <div class="form-group">
        <label>Phone No.:</label>
        <input class="input-std" type="tel" name="phoneNumber" id="reg-phone" autocomplete="tel" />
      </div>
      <div class="form-group">
        <label>Email:</label>
        <input class="input-std" type="email" name="email" id="reg-email" autocomplete="email" required />
      </div>
      <div class="form-group">
        <label>Password:</label>
        <input class="input-std" type="password" name="password" id="reg-password" autocomplete="current-password" required minlength="6" />
      </div>
      <div class="auth-actions">
        <button class="btn btn-red" type="submit" formaction="/register">Register</button>
        <button class="btn btn-yellow underline" type="submit" formaction="/login">Log In</button>
      </div>
      </form>
    </div>

    <script src="/basic.js"></script>
  </body>
</html>
