<!doctype html>
<html lang="en">
  <head><%- include('partials/head', { title: 'Home' }) %></head>

  <body class="auth-page">
     <%- include('partials/nav', { navClass: 'nav-center' }) %>


    <div class="auth-card card">
      <div class="form-group">
        <label>First Name:</label>
        <input
          class="input-std"
          type="text"
          id="reg-name"
          autocomplete="given-name"
        />
      </div>
      <div class="form-group">
        <label>Surname:</label>
        <input
          class="input-std"
          type="text"
          id="reg-surname"
          autocomplete="family-name"
        />
      </div>
      <div class="form-group">
        <label>Phone No.:</label>
        <input class="input-std" type="tel" id="reg-phone" autocomplete="tel" />
      </div>
      <div class="form-group">
        <label>Email:</label>
        <input
          class="input-std"
          type="email"
          id="reg-email"
          autocomplete="email"
        />
      </div>
      <div class="form-group">
        <label>Password:</label>
        <input
          class="input-std"
          type="password"
          id="reg-password"
          autocomplete="new-password"
        />
      </div>
      <div class="auth-actions">
        <button class="btn btn-red" onclick="handleRegister(event)">
          Register
        </button>
        <button class="btn btn-yellow underline" onclick="handleLogin(event)">
          Log In
        </button>
      </div>
    </div>

    <script src="basic.js"></script>
  </body>
</html>
