<!doctype html>
<html lang="en">
  <head><%- include('partials/head', { title: 'Bookings' }) %></head>
  <body>
       <%- include('partials/nav', { navLinks: [
    { href: '/contact',  label: 'Contact' },
    { href: '/events',   label: 'Events' },
    { href: '/logout',   label: 'Sign Out', cls: 'nav-signout' }
  ]}) %>
  

    <div class="page-content">
      <div class="bookings-wrap">
        <!-- Left: Purchase panel -->
        <div>
          <div class="purchase-panel card">
            <div class="purchase-label">Purchase Tickets:</div>
            <div class="purchase-event-name" id="booking-event-name">
              MOUNTAIN LIGHTS
            </div>

            <div class="purchase-row">
              <span>Price per Ticket:</span>
              <span id="booking-unit-price">R 0.00</span>
            </div>

            <div class="purchase-row">
              <span>Amount:</span>
              <div style="display: flex; align-items: center; gap: 0.5rem">
                <input
                  class="amount-input"
                  type="number"
                  id="ticket-amount"
                  value="1"
                  min="1"
                  oninput="updateTotal()"
                />
                <svg
                  id="qty-check"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#6ef06e"
                  stroke-width="2.5"
                  style="opacity: 0; transition: opacity 0.2s"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </div>
            </div>

            <div class="purchase-total">
              <span>Total Cost:</span>
              <span id="booking-total">R 0.00</span>
            </div>

            <div class="purchase-actions">
              <a class="btn btn-yellow btn-sm" href="events.html">Cancel</a>
              <button
                class="btn btn-red btn-sm underline"
                onclick="handleBookTickets(event)"
              >
                Book Tickets ›
              </button>
            </div>
          </div>
        </div>

        <!-- Right: Booking history — replace with API response -->
        <div>
          <div class="section-header">Booking History:</div>
          <div id="booking-history">
            <div class="booking-item card">
              <span class="b-name">Mountain Lights</span>
              <div>
                <span class="b-key">Event Date</span>
                <span class="b-val">01 Jul 2025</span>
              </div>
              <div>
                <span class="b-key">Purchase Date</span>
                <span class="b-val">14 Jun 2025 14:35</span>
              </div>
              <div>
                <span class="b-key">Tickets</span> <span class="b-val">2</span>
              </div>
              <div>
                <span class="b-key">Total Cost</span>
                <span class="b-val">R 407.01</span>
              </div>
            </div>
            <div class="booking-item card">
              <span class="b-name">Mountain Lights</span>
              <div>
                <span class="b-key">Event Date</span>
                <span class="b-val">01 Jul 2025</span>
              </div>
              <div>
                <span class="b-key">Purchase Date</span>
                <span class="b-val">14 Jun 2025 14:35</span>
              </div>
              <div>
                <span class="b-key">Tickets</span> <span class="b-val">2</span>
              </div>
              <div>
                <span class="b-key">Total Cost</span>
                <span class="b-val">R 407.01</span>
              </div>
            </div>
            <div class="booking-item card">
              <span class="b-name">Mountain Lights</span>
              <div>
                <span class="b-key">Event Date</span>
                <span class="b-val">01 Jul 2025</span>
              </div>
              <div>
                <span class="b-key">Purchase Date</span>
                <span class="b-val">14 Jun 2025 14:35</span>
              </div>
              <div>
                <span class="b-key">Tickets</span> <span class="b-val">2</span>
              </div>
              <div>
                <span class="b-key">Total Cost</span>
                <span class="b-val">R 407.01</span>
              </div>
            </div>
            <div class="booking-item card">
              <span class="b-name">Mountain Lights</span>
              <div>
                <span class="b-key">Event Date</span>
                <span class="b-val">01 Jul 2025</span>
              </div>
              <div>
                <span class="b-key">Purchase Date</span>
                <span class="b-val">14 Jun 2025 14:35</span>
              </div>
              <div>
                <span class="b-key">Tickets</span> <span class="b-val">2</span>
              </div>
              <div>
                <span class="b-key">Total Cost</span>
                <span class="b-val">R 407.01</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="basic.js"></script>
    <script>
      // Populate purchase panel from sessionStorage on page load
      document.addEventListener("DOMContentLoaded", initBookingPage);
    </script>
  </body>
</html>
