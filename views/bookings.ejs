<!doctype html>
<html lang="en">
  <head><%- include('partials/head', { title: 'Bookings' }) %></head>
  <body>
       <%- include('partials/nav', { navLinks: [
    { href: '/contact',  label: 'Contact' },
    { href: '/events',   label: 'Events' },
    { href: '/logout',   label: 'Sign Out', cls: 'nav-signout' }
  ]}) %>

    <div class="page-content">
      <div class="bookings-wrap">
        <!-- Left: Purchase panel -->
                <!-- Left: Purchase panel -->
        <div>
          <div class="purchase-panel card">
            <div class="purchase-label">Purchase Tickets:</div>
            
            <% if (booking) { %>
              <!-- ACTIVE STATE: User clicked an event -->
              <div class="purchase-event-name" id="booking-event-name">
                <%= booking.eventName.toUpperCase() %>
              </div>

              <div class="purchase-row">
                <span>Price per Ticket:</span>
                <span id="booking-unit-price">R <%= Number(booking.pricePerTicket).toFixed(2) %></span>
              </div>

              <div class="purchase-row">
                <span>Amount:</span>
                <div style="display: flex; align-items: center; gap: 0.5rem">
                  <input
                    class="amount-input"
                    type="number"
                    id="ticket-amount"
                    value="1"
                    min="1"
                    oninput="updateTotal()"
                  />
                  <svg
                    id="qty-check"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#6ef06e"
                    stroke-width="2.5"
                    style="opacity: 0; transition: opacity 0.2s"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </div>
              </div>

              <div class="purchase-total">
                <span>Total Cost:</span>
                <!-- Multiplied by 1 initial ticket layout load -->
                <span id="booking-total">R <%= Number(booking.pricePerTicket).toFixed(2) %></span>
              </div>

              <div class="purchase-actions">
                <a class="btn btn-yellow btn-sm" href="/events">Cancel</a>
                <button
                 class="btn btn-red btn-sm underline" 
                 id="book-tickets-btn"
                 onclick="handleBookTickets(event)">
                  Book Tickets ›
                </button>
              </div>

            <% } else { %>
              <!-- EMPTY STATE: User visited /bookings directly without choosing an event -->
              <div class="purchase-event-name" style="color: #999;">
                NO EVENT SELECTED
              </div>
              <p style="margin: 15px 0; font-size: 0.9rem; color: #666;">
                Please select an event from the main listing page first.
              </p>
              <div class="purchase-actions">
                <a class="btn btn-yellow btn-sm" href="/events">Browse Events</a>
              </div>
            <% } %>

          </div>
        </div>

        <!-- Right: Booking history — replace with API response -->
       <div>
  <div class="section-header">Booking History:</div>
  <div id="booking-history">
    <% if (history && history.length > 0) { %>
      <% history.forEach(function(item) { %>
        
        <!-- Dynamic Booking Card -->
        <div class="booking-item card">
          <span class="b-name"><%= item.eventTitle %></span>
          <div>
            <span class="b-key">Event Date</span>
            <span class="b-val"><%= item.eventDate %></span>
          </div>
          <div>
            <span class="b-key">Purchase Date</span>
            <span class="b-val"><%= item.createdAt %></span>
          </div>
          <div>
            <span class="b-key">Tickets</span> 
            <span class="b-val"><%= item.quantity %></span>
          </div>
          <div>
            <span class="b-key">Total Cost</span>
            <!-- Explicitly sets R currency format and pins decimal output precision -->
            <span class="b-val">R <%= Number(item.totalAmount).toFixed(2) %></span>
          </div>
        </div>

      <% }); %>
    <% } else { %>
      <!-- Fallback container state if the history array is completely empty -->
      <div class="booking-item card empty-state-card">
        <span class="b-name">No Bookings Found</span>
        <p class="event-desc" style="margin-top: 10px;">You have not booked any tickets to events yet.</p>
      </div>
    <% } %>
  </div>
</div>
      </div>
    </div>

    <script src="basic.js"></script>
    <script>
      // Populate purchase panel from sessionStorage on page load
      document.addEventListener("DOMContentLoaded", initBookingPage);
    </script>
  </body>
</html>
