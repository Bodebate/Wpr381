<!doctype html>
<html lang="en">
  <head><%- include('partials/head', { title: 'Admin: Events' }) %></head>
  <body>
      <%- include('partials/nav', { navLinks: [
    { href: '/bookings',         label: 'Bookings' },
    { href: '/admin/enquiries',  label: 'Enquiries' },
    { href: '/admin/analytics',  label: 'Analytics' },
    { href: '/logout',           label: 'Sign Out', cls: 'nav-signout' }
  ]}) %>
  
    <div class="page-content">
      <div class="control-cont card">
        <div class="search-bar">
          <input
            class="input-std"
            type="text"
            id="events-search"
            placeholder="Search events…"
            oninput="filterEvents()"
          />
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--dark-red)"
            stroke-width="2"
            style="cursor: pointer; flex-shrink: 0"
            onclick="filterEvents()"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="M22 22l-4.35-4.35" />
          </svg>
        </div>

        <div class="filter-bar">
          <label for="filter-from">FROM:</label>
          <input
            class="input-std badge badge-red"
            style="max-width: 145px"
            type="date"
            id="filter-from"
            title="From Date"
            onchange="filterEvents()"
          />
          <label for="filter-to">TO:</label>
          <input
            class="input-std badge badge-red"
            style="max-width: 145px"
            type="date"
            id="filter-to"
            title="To Date"
            onchange="filterEvents()"
          />
          <select
            class="select-std badge badge-yellow"
            id="filter-category"
            onchange="filterEvents()"
          >
            <option value="">Select Category</option>
            <option value="Outdoors">Outdoors</option>
            <option value="Indoors">Indoors</option>
            <option value="Quiet">Quiet</option>
            <option value="Crowd">Crowd</option>
          </select>
          <select
            class="select-std badge badge-yellow"
            id="filter-seats"
            onchange="filterEvents()"
          >
            <option value="">Select Seats</option>
            <option value="0">Any Availability</option>
            <option value="1">1+ Seats</option>
            <option value="5">5+ Seats</option>
            <option value="10">10+ Seats</option>
            <option value="50">50+ Seats</option>
            <option value="100">100+ Seats</option>
          </select>
        </div>
      </div>
      <!-- Create / Edit Form -->
      <div class="create-panel card" id="create-panel">
        <% if (createError) { %>
          <div class="auth-error" style="margin-bottom:0.8rem"><%= createError %></div>
        <% } %>
        <form action="/admin/events" method="POST">
        <div class="create-row">
          <input class="input-std" type="text"   name="title"     placeholder="Event Name" id="new-title" />
          <input class="input-std" type="text"   name="venue"     placeholder="Venue"       id="new-venue" />
          <input class="input-std" type="date"   name="eventDate"                           id="new-date" />
          <input class="input-std" type="time"   name="startTime" placeholder="Start Time"  id="new-start-time" />
          <input class="input-std" type="time"   name="endTime"   placeholder="End Time"    id="new-end-time" />
          <input class="input-std" type="number" name="totalCapacity" placeholder="Seat Amt." id="new-capacity" min="1" />
          <input class="input-std" type="number" name="price"     placeholder="Seat Price"  id="new-price" step="0.01" min="0" />
          <label class="btn btn-outline btn-sm" style="cursor:pointer">
            Upload Image
            <input type="file" accept="image/*" id="image-upload-input" style="display:none" />
          </label>
          <button class="btn btn-yellow btn-sm" type="submit" id="create-event-btn">Create</button>
          <button class="btn btn-outline btn-sm" type="button" id="update-event-btn">Update</button>
          <button class="panel-toggle" id="create-panel-toggle" type="button"
            onclick="toggleCreatePanel('create-panel-body', 'create-panel-toggle')" title="Collapse">∨</button>
        </div>
        <div id="create-panel-body">
          <div class="form-group" style="margin-bottom:0.8rem">
            <textarea class="input-std" name="description" id="new-description"
              rows="6" style="resize:vertical" placeholder="Event description…"></textarea>
          </div>
          <div class="category-section">
            <span class="label">Category</span>
            <div class="radio-group">
              <label class="radio-label"><input type="radio" name="categoryId" value="Quiet" /> Quiet</label>
              <label class="radio-label"><input type="radio" name="categoryId" value="Crowd" /> Crowd</label>
              <label class="radio-label"><input type="radio" name="categoryId" value="Indoors" /> Indoors</label>
              <label class="radio-label"><input type="radio" name="categoryId" value="Outdoors" checked /> Outdoors</label>
            </div>
          </div>
        </div>
        </form>
      </div>

      <!-- Admin event list -->
      <div id="admin-events-list">
        <% if (events && events.length > 0) { %>
          <% events.forEach(ev => { %>
            <div class="event-card card" data-category="<%= ev.category %>" data-seats="<%= ev.availableTickets %>">
              <div class="event-img">
                <div class="event-img-inner">
                  <img src="<%= ev.imageUrl || '/images/boats.jpg' %>" alt="<%= ev.title %>" />
                </div>
                <div class="event-footer">
                  <span class="event-date"><%= ev.eventDate %> &nbsp;|&nbsp; <%= ev.startTime %> – <%= ev.endTime %></span>
                </div>
              </div>
              <div class="event-body">
                <div class="event-header">
                  <form action="/admin/events/<%= ev._id %>/delete" method="POST" style="display:contents">
                    <button class="btn btn-danger btn-sm" type="submit" onclick="return confirm('Permanently delete this event?')">Delete</button>
                  </form>
                  <button class="btn btn-yellow btn-sm" type="button" data-id="<%= ev._id %>" onclick="loadEventForEdit('<%= ev._id %>')">Edit</button>
                  <span class="badge event-title"><%= ev.title %></span>
                  <span class="badge badge-red"><%= ev.category %></span>
                  <span class="badge badge-red"><%= ev.availableTickets %> Seats Left</span>
                </div>
                <p class="event-desc"><%= ev.description %></p>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="no-events card"><p>No events found.</p></div>
        <% } %>
      </div>
    </div>

    <script src="/basic.js"></script>
  </body>
</html>
